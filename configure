#!/bin/sh

# ------------------------------------------------------------------------------
# data

cudddir="cudd-3.0.0";

# defaults

prefix="/usr/local";

# usage

usage () {
    cat <<EOF
usage: $0 [options]
where available options are:
  --prefix <prefix>  Specify installation prefix directory
                     ("$prefix" by default)
  --docdir <docdir>  Specify documentation installation directory
                     ("\$prefix/share/doc" by default)
  --help             Display this help and exit
EOF
    exit 0
}

# ---

info () { echo "$1" >/dev/stderr; return 0; }
warn () { echo "$1" >/dev/stderr; return 0; }
err () { echo "$1" >/dev/stderr; exit 1; }
arr () { echo "Missing argument for \`$1'!" >/dev/stderr; usage; exit 1; }
arg () { test "x$2" != "x" && echo "$2" || arr "$1"; }
drg () { d="$(arg "$@")"; test -d "$d" && echo "$d" || \
		 err "Argument for \`$1' should be an existing directory!"; }

# arg. parsing

while test $# '>' 0; do
    case "$1" in
	--prefix) prefix="$(arg "$1" "$2")"; shift; shift;;
	-h | --help) usage;;
	*) warn "Ignoring argument \`$1'!"; shift;;
    esac;
done;

# ---

# ( cd "${cudddir}" && ./configure --prefix "${prefix}"; )

out () { echo "$*"; return 0; }
test_cmd () { command -v $1 >/dev/null; }
find_cmd () {
    if test_cmd $1; then
	cmd=$(command -v $1);
	test "x$2" != "x" && test "x$2" != "x_" && out "$1 = $cmd";
	test "x$3" != "x" && info "$3 found: $cmd" || info "$1 found: $cmd";
    else
	test "x$3" != "x" && err "$3 not found" || err "$1 not found";
    fi
}
maybe_cmd () { find_cmd $2 $3 $1 || warn "$3 seems unavailable"; }
maybe_cme () { test -z "$4" && maybe_cmd "$@" || out "$1 = $4"; }

# Basic test to guess architecture:
test_cmd uname || err "Unable to guess ISA!";

# Note we always assume a decent version of gcc here:
exec 1>"Makefile.config";
cat Makefile.config.in;

system=$(uname -s);
info "Detected System: ${system}";

find_cmd mktemp;
find_cmd ar AR;
find_cmd ranlib RANLIB;
find_cmd camlidl CAMLIDL;
case "${system}" in
    Linux)
        find_cmd sed SED;
        find_cmd m4 M4;;
    Darwin)
        find_cmd gsed SED "GNU sed";
        find_cmd gm4 M4 "GNU m4";;
    FreeBSD)
        find_cmd gsed SED "GNU sed";
        find_cmd gm4 M4 "GNU m4";
        maybe_cme clang CC "LLVM/clang" "$CC";
        # NB: not used actually:
        maybe_cme clang++ CXX "LLVM/clang++" "$CXX";;
    *)
        warn "Unknown system: ${system}!";;
esac;


overs=$(ocamlc -version);
case "${overs}" in
    [1-3].* | 4.01.*)
	err "OCaml version found is ${overs}: OCaml >= 4.02 is required.";;
    *)
	:;;
esac

test_cmd awk && {
    find_cmd awk;
    echo "OCAMLPACK = ./ocamlpack";
} || warn "awk not found: documentation will not be built";

cprof_flags="$(ocamlc -config | sed -e '/^cc_profile:/!d; s/^[^:]*://;')";
info "Profiling flags: ${cprof_flags}";
echo "CPROF_FLAGS = ${cprof_flags}";

# NB: Ugly hack to avoid weird errors with auto{conf,make} and the likes:
( cd "${cudddir}" && touch configure.ac aclocal.m4 configure Makefile.am Makefile.in config.h.in; )
